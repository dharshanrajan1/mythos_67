generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

// ─── Nutrition enums (ported from iMessage AI) ────────────────────────────────

enum GoalType {
  LOSE
  MAINTAIN
  GAIN
}

enum MealEventType {
  MEAL_LOG
  CORRECTION
  DELETE
}

enum LoggingState {
  PENDING
  CONFIRMED
  AUTO_LOGGED
  NEEDS_CLARIFICATION
}

enum FoodSource {
  USDA
  BRANDED
  MANUAL
  LLM_ESTIMATE
}

enum OnboardingStep {
  GOAL
  BODY_STATS
  ACTIVITY
  DIET
  COMPLETE
}

enum ThreadTransport {
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── NextAuth models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  // iMessage / SMS identity
  phoneE164     String?   @unique
  timezone      String    @default("America/New_York")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts       Account[]
  sessions       Session[]

  // Meridian feature relations
  diaryEntries   DiaryEntry[]
  weightLogs     WeightLog[]
  progressPhotos ProgressPhoto[]
  noteBlocks     NoteBlock[]
  tasks          Task[]
  workoutLogs    WorkoutLog[]
  countdowns     Countdown[]
  mediaItems     MediaItem[]

  // Nutrition / iMessage coach relations
  nutritionProfile    Profile?
  nutritionGoals      Goal[]
  smsThreads          Thread[]
  mealEvents          MealEvent[]
  dailyRollups        DailyRollup[]
  coachMemory         CoachMemory?
  nutritionCorrections Correction[]
  nutritionOnboarding OnboardingSession?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Meridian features ────────────────────────────────────────────────────────

model DiaryEntry {
  id        String   @id @default(cuid())
  date      DateTime
  content   String
  rating    String?  // GOOD, MID, BAD
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  date      DateTime
  weight    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  date      DateTime
  url       String
  caption   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model NoteBlock {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // text, link, idea
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  content     String
  notes       String?
  status      String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  day         String   @default("Monday") // Monday, Tuesday, etc.
  priority    String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  weekOf      String?  // YYYY-MM-DD of the Monday of the week this task belongs to
  gcalEventId String?  // Google Calendar event ID for two-way sync
  startTime   String?  // "HH:MM" 24h — present means timed event, absent means all-day task
  endTime     String?  // "HH:MM" 24h — defaults to startTime + 1h when syncing if omitted
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime
  workout   String
  isPR      Boolean  @default(false)
  exercises Json?    // Array<{name:string, sets:[{weight:number, reps:number, isPR:boolean}]}>
  duration  Int?     // Minutes (cardio workouts)
  notes     String?  // Free-text notes (cardio pace, distance, etc.)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Countdown {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MediaItem {
  id         String   @id @default(cuid())
  title      String
  type       String   // BOOK, MOVIE, TV_SHOW
  status     String   @default("WANT_TO") // WANT_TO, IN_PROGRESS, DONE
  rating     Int?     // 1-5
  notes      String?
  posterUrl  String?  // TMDB poster or Google Books thumbnail
  externalId String?  // TMDB ID or Google Books volume ID
  year       Int?     // Release / publication year
  author     String?  // Book author(s) or movie director
  rank       Float?   // Fractional rank within DONE items (lower = better)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Nutrition & iMessage coach ───────────────────────────────────────────────

model Profile {
  userId               String   @id
  firstName            String?
  sex                  String?
  birthYear            Int?
  heightCm             Float?
  startWeightKg        Float?
  currentWeightKg      Float?
  activityLevel        String?
  exerciseDaysPerWeek  Int?
  dietaryPreferences   Json?
  allergies            Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  goalType        GoalType
  targetWeightKg  Float?
  weeklyPaceKg    Float?
  targetCalories  Int?
  targetProteinG  Int?
  targetCarbsG    Int?
  targetFatG      Int?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id               String          @id @default(cuid())
  userId           String
  transport        ThreadTransport
  externalThreadId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
}

model Message {
  id                String           @id @default(cuid())
  threadId          String
  direction         MessageDirection
  provider          String
  providerMessageId String?          @unique
  bodyText          String?
  mediaCount        Int              @default(0)
  receivedAt        DateTime         @default(now())
  rawPayload        Json?
  createdAt         DateTime         @default(now())
  thread            Thread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mediaAssets       MediaAsset[]
  sourceMealEvents  MealEvent[]      @relation("SourceMessage")
  clarificationFor  Clarification[]  @relation("ClarificationAnswer")
}

model MediaAsset {
  id               String   @id @default(cuid())
  messageId        String
  providerMediaUrl String
  mimeType         String?
  storageKey       String?
  width            Int?
  height           Int?
  createdAt        DateTime @default(now())
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MealEvent {
  id              String        @id @default(cuid())
  userId          String
  sourceMessageId String?
  eventType       MealEventType
  mealTime        DateTime?
  loggingState    LoggingState  @default(PENDING)
  confidenceScore Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMessage   Message?      @relation("SourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  mealItems       MealItem[]
  clarifications  Clarification[]
}

model MealItem {
  id              String     @id @default(cuid())
  mealEventId     String
  nameRaw         String
  nameCanonical   String?
  quantity        Float?
  unit            String?
  gramsEstimated  Float?
  foodSource      FoodSource @default(LLM_ESTIMATE)
  foodSourceRef   String?
  calories        Float?
  proteinG        Float?
  carbsG          Float?
  fatG            Float?
  fiberG          Float?
  confidenceScore Float?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  mealEvent       MealEvent  @relation(fields: [mealEventId], references: [id], onDelete: Cascade)
  corrections     Correction[]
}

model Clarification {
  id              String    @id @default(cuid())
  mealEventId     String
  question        String
  answerMessageId String?   @unique
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  mealEvent       MealEvent @relation(fields: [mealEventId], references: [id], onDelete: Cascade)
  answerMessage   Message?  @relation("ClarificationAnswer", fields: [answerMessageId], references: [id], onDelete: SetNull)
}

model DailyRollup {
  id          String   @id @default(cuid())
  userId      String
  dayDate     DateTime
  calories    Float    @default(0)
  proteinG    Float    @default(0)
  carbsG      Float    @default(0)
  fatG        Float    @default(0)
  fiberG      Float    @default(0)
  mealsLogged Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayDate])
}

model CoachMemory {
  userId               String   @id
  summary              String?
  strictnessMode       String?
  preferredCheckinTime String?
  lastWeekSummary      Json?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Correction {
  id             String    @id @default(cuid())
  userId         String
  mealItemId     String?
  correctionType String
  oldValue       Json?
  newValue       Json?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItem       MealItem? @relation(fields: [mealItemId], references: [id], onDelete: SetNull)
}

model OnboardingSession {
  userId      String         @id
  currentStep OnboardingStep @default(GOAL)
  answers     Json?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}
